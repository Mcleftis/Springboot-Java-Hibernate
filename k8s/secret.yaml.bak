apiVersion: v1
kind: Secret
metadata:
  name: postgres-credentials
  namespace: quant-trading
  labels:
    team: Cybersecurity
type: Opaque
stringData:
  quantdb-url: jdbc:postgresql://postgres:5432/quantdb
  database_url: postgresql://quant_user:fleetpass@postgres:5432/quantdb
  username: quant_user
  password: fleetpass
